# ============================================================================
# Elogia v4 Production Environment Configuration Template
# ============================================================================
# NEVER commit actual values to version control!
# Use .env.production.local for deployment-specific values in Dokploy
# ============================================================================

APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=Agentic SDR API

# Database - MUST use secure password in production
DATABASE_URL=postgresql+asyncpg://elogia_user:YOUR_SECURE_PASSWORD_HERE@postgres:5432/elogia_db
ALEMBIC_DB_URL=postgresql+asyncpg://elogia_user:YOUR_SECURE_PASSWORD_HERE@postgres:5432/elogia_db

# Security - Generate unique value per deployment
SECRET_KEY=YOUR_SECURE_SECRET_KEY_HERE
CORS_ORIGINS=["https://elogia.muradmadi.com"]

# Public URLs
PUBLIC_BASE_URL=https://api.muradmadi.com

# Clay Integration - Replace with actual values
CLAY_WEBHOOK_URL=YOUR_CLAY_WEBHOOK_URL_HERE
CLAY_WEBHOOK_AUTH_TOKEN=YOUR_CLAY_WEBHOOK_AUTH_TOKEN_HERE

# n8n Integration - Replace with actual values
N8N_SHREDDER_WEBHOOK_URL=https://muradmadi.app.n8n.cloud/webhook/YOUR_WORKFLOW_WEBHOOK_URL

# AI/LLM - Replace with actual API key
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
ANTHROPIC_MAX_TOKENS=10000

# Storage
STORAGE_DIR=storage/pdfs

# Logging
LOG_LEVEL=INFO
