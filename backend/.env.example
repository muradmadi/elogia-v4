# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/elogia_db

# Application Configuration
APP_NAME=Agentic SDR API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Security
SECRET_KEY=your-secret-key-here-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Alembic
ALEMBIC_DB_URL=postgresql+asyncpg://user:password@localhost:5432/elogia_db

# Clay Webhook Integration
CLAY_WEBHOOK_URL=your-clay-webhook-url-here
CLAY_WEBHOOK_AUTH_TOKEN=your-clay-webhook-auth-token-here
PUBLIC_BASE_URL=http://localhost:8000

# AI API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
