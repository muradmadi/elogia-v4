# ============================================================================
# Elogia v4 Development Environment Configuration
# ============================================================================
# NEVER commit actual secrets to version control!
# This is a safe template with placeholder values for development
# ============================================================================

# Database Configuration
DATABASE_URL=postgresql+asyncpg://elogia_user:elogia_password@postgres:5432/elogia_db
ALEMBIC_DB_URL=postgresql+asyncpg://elogia_user:elogia_password@postgres:5432/elogia_db

# Application Configuration
APP_NAME=Agentic SDR API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Security
SECRET_KEY=your-secret-key-here-change-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO

# Webhook Integration
CLAY_WEBHOOK_URL=your-clay-webhook-url-here
CLAY_WEBHOOK_AUTH_TOKEN=your-clay-webhook-auth-token-here

# n8n Webhook Integration
N8N_SHREDDER_WEBHOOK_URL=http://localhost:5678/webhook/content-shredder

# Public Base URL (used for callback URLs in both Clay and n8n webhooks)
PUBLIC_BASE_URL=http://localhost:8000

# AI API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MAX_TOKENS=10000

# Storage
STORAGE_DIR=storage/pdfs
