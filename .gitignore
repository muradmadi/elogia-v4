# Global .gitignore for Elogia Monorepo
# Patterns here apply to the entire repository

# Roo Code Configuration (AI assistant files)
.roo/
.roomodes

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Global Environment Files
.env
.env.local
.env.*.local
.env.production
.env.production.local

# Log Files
*.log
logs/

# Temporary Files
*.tmp
*.temp

# Git Files (should not be ignored in repos, but useful for local)
# .git/

# Node.js (will be overridden by frontend/.gitignore if needed)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (will be overridden by backend/.gitignore if needed)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# Build artifacts
build/
dist/
*.egg-info/

# Test coverage
.coverage
htmlcov/

# IDE specific (already covered above)

# Project-specific ignores
backend/storage/
docker-compose.yml.bak
frontend/.astro/
