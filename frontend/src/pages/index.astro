---
import Layout from "../components/layout/Layout.astro";
import { Navbar } from "../components/layout/Navbar";
import { Button } from "../components/ui/button";
---

<Layout title="Home">
  <Navbar client:load />

  <main class="mx-auto max-w-5xl px-6 py-12">
    <!-- Hero Text -->
    <section class="mb-16 text-center">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
        Admission Project for Junior GTM Engineer @ Elogia
      </h1>
    </section>

    <!-- Bento Grid -->
    <section class="mb-16 grid gap-4 sm:grid-cols-[1fr_2fr] sm:grid-rows-[auto_auto]">
      <!-- Photo (square, left column, spans both rows) -->
      <div class="overflow-hidden rounded-lg border border-border bg-card sm:row-span-2">
        <img
          src="/profile.jpg"
          alt="Profile photo"
          class="aspect-square h-full w-full object-cover"
        />
      </div>

      <!-- Description (right column, top) -->
      <div class="flex items-center rounded-lg border border-border bg-card p-8">
        <p class="text-lg leading-relaxed text-muted-foreground">
          I chose to submit a fully functional web application rather than a static document to directly reflect the practical demands of the AI GTM Engineer role. While a PDF can effectively outline a theoretical workflow, a live application provides a tangible demonstration of systems thinking in action. This format allows me to move beyond explaining the strategy and actually show the execution—illustrating exactly how I orchestrate LLMs, manage data pipelines, and translate a conceptual outbound sequence into a deployed, scalable engine.
        </p>
      </div>

      <!-- Links (right column, bottom) -->
      <div class="flex flex-col gap-3 rounded-lg border border-border bg-card p-6">
        <a
          href="https://github.com/muradmadi/elogia-v4"
          class="flex items-center gap-3 rounded-md px-4 py-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/muradmadi/"
          class="flex items-center gap-3 rounded-md px-4 py-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </section>

    <!-- Feature Links -->
    <section class="flex justify-center gap-4">
      <a href="/enrichment">
        <Button variant="default" className="rounded-full px-6">
          Enrichment
        </Button>
      </a>
      <a href="/prompting">
        <Button variant="default" className="rounded-full px-6">
          Prompting
        </Button>
      </a>
      <a href="/content">
        <Button variant="default" className="rounded-full px-6">
          Content
        </Button>
      </a>
    </section>
  </main>
</Layout>
